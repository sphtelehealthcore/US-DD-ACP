# 03. PLOTTING

# 03.2 Percentage of 5-domain completion ----
summary_df <- df_IADL_us %>%
  pivot_longer(cols = c(MedicalDecision_ever, MedicalWorth_ever, MedicalEnd_ever, MedicalFlex_ever, MedicalAskDoc_ever, highstakeMed_ever),
               names_to = "variable", values_to = "response") %>%
  group_by(variable) %>%
  summarise(
    p = mean(response == "1 - Done before"),
    n = n(),
    se = sqrt(p * (1 - p) / n),
    lower = p - 1.96 * se,
    upper = p + 1.96 * se,
    .groups = "drop"
  ) %>%
  mutate(
    lower = pmax(0, lower),
    upper = pmin(1, upper),
    variable = factor(variable, levels = c("MedicalAskDoc_ever", "MedicalFlex_ever", "MedicalEnd_ever", "MedicalWorth_ever", "MedicalDecision_ever", "highstakeMed_ever"),
                      labels = c("Asking Questions of medical providers",
                                 "Flexibility for surrogate decision making",
                                 "Quality of Life (Medical Care)",
                                 "Quality of Life (Health Situations)",
                                 "Role of Medical Decision Making",
                                 "Discussed any SDM domains"))
  )

ggplot(summary_df, aes(x = variable, y = p)) +
  geom_col(fill = "darkorange") +
  geom_errorbar(aes(ymin = lower, ymax = upper), width = 0.2) +
  geom_text(
    aes(label = paste0(formatC(100 * p, format = "f", digits = 1), "%")),  # format label -> formatC is there to force 1dp
    hjust = -0.5,                                # position to the right of the bar
    size = 4
  ) +
  scale_y_continuous(labels = percent_format(accuracy = 0.1),
                     limits = c(0,1)) +
  labs(x = NULL, y = NULL) +
  coord_flip() +
  theme_minimal()

#---- Theme setting ----
# Custom reusable theme for consistency
theme_setting <- theme_minimal() +
  theme(
    legend.position = "bottom",
    legend.title = element_text(size = 14, face = "bold"),
    legend.text  = element_text(size = 12),
    axis.ticks.y = element_blank(),
    axis.title.y = element_blank(),
    axis.text.y = element_text(size = 14, color = "black"),
    axis.text.x = element_text(size = 12, color = "black"),
    panel.grid.major = element_blank(),
    panel.grid.minor = element_blank()
  )

colvars = c("MedicalDecision_ever", "MedicalWorth_ever", "MedicalEnd_ever", "MedicalFlex_ever", "MedicalAskDoc_ever", "highstakeMed_ever")

